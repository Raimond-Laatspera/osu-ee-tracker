generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GameMode {
  OSU
  TAIKO
  FRUITS
  MANIA
}

model Player {
  id            Int @id
  username      String
  country       String
  modes         GameMode[]
  avatarUrl     String?
  globalRank    Int?
  countryRank   Int?

  lastPolledAt  DateTime?
  lastScoreAt   DateTime?

  scores        Score[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Beatmap {
  id               Int @id
  beatmapsetId     Int

  artist           String
  title            String
  version          String

  mode             GameMode

  difficultyRating Float?

  bpm              Float?

  totalLength      Int?
  hitLength        Int?

  ar               Float?
  od               Float?
  hp               Float?
  cs               Float?

  maxCombo         Int?

  keyCount         Int?

  scores           Score[]

  createdAt        DateTime @default(now())

  @@index([mode])
  @@index([difficultyRating])
  @@index([ar])
  @@index([od])
}

model Score {
  id             BigInt @id
  isLazer        Boolean?
  playerId       Int
  beatmapId      Int

  player         Player @relation(fields: [playerId], references: [id])
  beatmap        Beatmap @relation(fields: [beatmapId], references: [id])

  gameMode       GameMode

  pp             Float
  accuracy       Float

  score          BigInt?
  combo          Int?

  count300       Int?
  count100       Int?
  count50        Int?
  countMiss      Int?

  countGeki      Int?
  countKatu      Int?

  mods           Int?

  rank           String?

  effectiveAr    Float?
  effectiveOd    Float?
  effectiveCs    Float?
  effectiveHp    Float?

  effectiveBpm         Float?
  effectiveStarRating  Float?

  createdAt      DateTime

  @@index([createdAt])
  @@index([playerId, createdAt])
  @@index([playerId, pp])
  @@index([playerId, gameMode, createdAt])
  @@index([beatmapId])
  @@index([gameMode, createdAt])

  @@index([pp])
  @@index([accuracy])

  @@index([mods])

  @@index([effectiveAr])
  @@index([effectiveOd])

  @@index([effectiveBpm])
  @@index([effectiveStarRating])

  @@unique([playerId, beatmapId, createdAt])
}