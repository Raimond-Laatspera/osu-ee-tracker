generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GameMode {
  OSU
  TAIKO
  FRUITS
  MANIA
}

enum ManiaKeys {
  FOUR
  SEVEN
}

model Player {
  id            Int @id
  username      String
  country       String
  modes         GameMode[]
  avatarUrl     String?
  globalRank    Int?
  countryRank   Int?

  lastPolledAt  DateTime?
  lastScoreAt   DateTime?

  scores        Score[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Beatmap {
  id            Int @id
  beatmapsetId  Int

  artist        String
  title         String
  version       String

  mode          GameMode

  difficultyRating Float?
  bpm           Float?

  totalLength   Int?
  hitLength     Int?

  scores        Score[]

  createdAt     DateTime @default(now())
}

model Score {
  id           BigInt   @id // osu score id

  playerId     Int
  beatmapId    Int

  player       Player   @relation(fields: [playerId], references: [id])
  beatmap      Beatmap  @relation(fields: [beatmapId], references: [id])

  gameMode     GameMode
  maniaKeys    ManiaKeys?

  pp           Float
  accuracy     Float

  combo        Int?
  score        BigInt?

  mods         Int?
  rank         String?

  createdAt    DateTime

  @@index([createdAt])
  @@index([playerId, createdAt])
  @@index([beatmapId])
  @@index([gameMode, createdAt])
}